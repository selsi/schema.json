{
  "$schema": "http://json-schema.org",
  "title": "TunisianLinguisticNode",
  "type": "object",
  "properties": {
    "conversation_id": { "type": "string" },
    "metadata": {
      "type": "object",
      "properties": {
        "location": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "environment_type": { "type": "string" },
            "impact_on_speech": { "type": "string" }
          }
        },
        "context_description": { "type": "string" }
      }
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "historical_background": {
            "type": "object",
            "properties": {
              "family_influence": { "type": "string" },
              "tribal_origin": { "type": "string" }
            }
          },
          "linguistic_profile": {
            "type": "object",
            "properties": {
              "accent": { "type": "string" },
              "vocabulary_type": { "type": "string" }
            }
          }
        }
      }
    },
    "data_extraction": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": { "type": "string" },
          "speaker": { "type": "string" },
          "literal_translation": { "type": "string" },
          "contextual_explanation": { "type": "string" },
          "linguistic_pattern": { "type": "string" }
        }
      }
    }
  }
}
